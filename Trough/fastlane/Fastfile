default_platform(:ios)

platform :ios do
  desc "Build, archive, and upload to TestFlight"
  lane :beta do
    # ── App Store Connect API auth ────────────────────────────────────────────
    # Option A (preferred): place the private key at fastlane/AuthKey_K34HFNJTXH.p8
    # Option B (CI/env):    set ASC_KEY_CONTENT to the raw .p8 file contents
    key_path = File.expand_path("AuthKey_K34HFNJTXH.p8", __dir__)

    api_key_params = {
      key_id:    "K34HFNJTXH",
      issuer_id: "69a6de84-f289-47e3-e053-5b8c7c11a4d1",
      duration:  1200,
      in_house:  false
    }

    if ENV["ASC_KEY_CONTENT"] && !ENV["ASC_KEY_CONTENT"].empty?
      api_key_params[:key_content] = ENV["ASC_KEY_CONTENT"]
    else
      api_key_params[:key_filepath] = key_path
    end

    api_key = app_store_connect_api_key(**api_key_params)

    # ── Code signing ─────────────────────────────────────────────────────────
    # Download/create distribution certificate and App Store provisioning profile
    # using the API key so no Xcode account sign-in is required.
    cert(
      api_key:       api_key,
      team_id:       "3N9RY9EG8V",
      output_path:   "build/certs"
    )
    sigh(
      api_key:        api_key,
      team_id:        "3N9RY9EG8V",
      app_identifier: "app.trough.ios",
      provisioning_name: "Trough App Store",
      output_path:    "build/profiles",
      force:          false
    )

    # ── Build number ─────────────────────────────────────────────────────────
    current_build = latest_testflight_build_number(
      api_key:        api_key,
      app_identifier: "app.trough.ios"
    )
    increment_build_number(
      build_number: current_build + 1,
      xcodeproj:    "Trough.xcodeproj"
    )

    # ── Archive ───────────────────────────────────────────────────────────────
    gym(
      scheme:           "Trough",
      project:          "Trough.xcodeproj",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "build",
      output_name:      "Trough.ipa",
      xcargs:           "DEVELOPMENT_TEAM=3N9RY9EG8V -allowProvisioningUpdates",
      clean:            true
    )

    # ── Upload ────────────────────────────────────────────────────────────────
    upload_to_testflight(
      api_key:                           api_key,
      app_identifier:                    "app.trough.ios",
      apple_id:                          "6760955550",
      skip_waiting_for_build_processing: true,
      distribute_external:               false
    )
  end
end
